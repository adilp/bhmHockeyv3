# Local development API URL.
# Copy this file to .env (gitignored) and uncomment ONE line for your platform.
# When no value is set, the app uses the production API.
#
# Env vars are inlined into the JS bundle — restart Metro after changing this:
#   npx expo start --clear

# iOS Simulator:
# EXPO_PUBLIC_API_URL=http://localhost:5001/api

# Android Emulator (10.0.2.2 = host machine):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5001/api

# Physical device (find your Mac's LAN IP: ipconfig getifaddr en0):
# EXPO_PUBLIC_API_URL=http://192.168.x.x:5001/api
